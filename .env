# Configurações de Envio de E-mail (SMTP Remetente)
# Deixe as variáveis SMTP em branco se quiser testar apenas localmente. O código OTP aparecerá automaticamente na tela.
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Chave criptográfica obrigatória (Deve ter no mínimo 32 caracteres)
# Troque essa chave se for rodar em Produção!
FLASK_SECRET_KEY=esta_e_uma_chave_secreta_padrao_para_desenvolvimento_local_1234
